# PoolTool 2026 frontend — optional overrides for API and WebSocket
# Set these when the UI is served from a different host than the API (e.g. S3 or local dev).
# Otherwise the app uses window.location.hostname:3004 and will not receive live block updates.
#
# Dev server on same machine as API (e.g. npm run serve on the server):
# VUE_APP_API_URL=http://localhost:3004
# VUE_APP_WS_URL=ws://localhost:3004/ws
#
# API on another host:
# VUE_APP_API_URL=http://YOUR_API_HOST:3004
# VUE_APP_WS_URL=ws://YOUR_API_HOST:3004/ws
#
# For HTTPS: use https:// and wss://
